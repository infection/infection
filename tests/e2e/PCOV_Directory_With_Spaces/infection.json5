{
    "$schema": "../../../resources/schema.json",
    "timeout": 25,
    "threads": 1,
    "source": {
        "directories": [
            "source files"
        ]
    },
    "logs": {
        "summary": "var/infection.log"
    },
    "phpUnit": {
        "customPath": "vendor/bin/phpunit"
    },
    "mutators": {
        "TrueValue": true
    },
    "tmpDir": "var/infection-tmp"
}
