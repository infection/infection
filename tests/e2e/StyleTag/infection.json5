{
    "$schema": "../../../resources/schema.json",
    "timeout": 25,
    "threads": 1,
    "source": {
        "directories": [
            "src"
        ]
    },
    "logs": {
        "summary": "infection.log"
    },
    "mutators": {
        "PregMatchRemoveFlags": true
    },
    "tmpDir": "."
}
